# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values before running bootstrap.sh
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Docker Compose project name — controls the prefix used for network/container
# names (e.g. <project>_ceph-net).  Set this so the name stays stable
# regardless of what directory you cloned the repo into.
COMPOSE_PROJECT_NAME=ceph_deployment

# Ceph container image (Reef / Ceph 18)
CEPH_IMAGE=quay.io/ceph/daemon:latest

# Monitor IP — must match the static IP assigned in docker-compose.yml
MON_IP=172.20.0.10
CEPH_PUBLIC_NETWORK=172.20.0.0/24

# Ceph Dashboard credentials
CEPH_DASHBOARD_PASSWORD=admin

# RADOS Gateway S3 credentials
RGW_S3_ACCESS_KEY=accesskey123
RGW_S3_SECRET_KEY=secretkey123
