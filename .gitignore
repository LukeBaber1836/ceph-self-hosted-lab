# ──────────────────────────────────────────────────────────────────────────────
# Ceph runtime data
# Generated by the monitor on first start; contains large binary blobs and
# device files that must not be committed.
# ──────────────────────────────────────────────────────────────────────────────
var/lib/ceph/mon/
var/lib/ceph/mgr/
var/lib/ceph/mds/
var/lib/ceph/radosgw/
var/lib/ceph/osd*/
var/lib/ceph/bootstrap-osd/
var/lib/ceph/bootstrap-mds/
var/lib/ceph/bootstrap-rgw/

# ──────────────────────────────────────────────────────────────────────────────
# Ceph keyrings (cryptographic secrets — never commit these)
# ──────────────────────────────────────────────────────────────────────────────
*.keyring
etc/ceph/ceph.client.admin.keyring
etc/ceph/ceph.mon.keyring

# ──────────────────────────────────────────────────────────────────────────────
# Environment / secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────────────────────────────────────
# macOS
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ──────────────────────────────────────────────────────────────────────────────
# Editors
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────────────────────────
docker-compose.override.yml
